<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="AppDialogTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:textColorPrimary">#f25a04</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
    </style>

    <style name="AppThemeCROP" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/rdo_gender_select</item>
        <item name="colorAccent">@color/rdo_gender_select</item>
        <item name="colorPrimary">@color/rdo_gender_select</item>
        <item name="colorPrimaryDark">@color/rdo_gender_select</item>
    </style>

    <style name="AppThemeSplash" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:soundEffectsEnabled">true</item>
        <item name="android:hapticFeedbackEnabled">true</item>
        <item name="android:navigationBarColor">@color/water_color</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="CardView.Dark">
        <item name="cardBackgroundColor">@color/cardview_dark_background</item>
    </style>

    <style name="CardView.Light">
        <item name="cardBackgroundColor">@color/cardview_light_background</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
    </style>

    <style name="MyDatePickerDialogTheme">
        <item name="android:colorAccent">?attr/colorPrimaryDark</item>
    </style>

    <style name="horizontal_line">
        <item name="android:background">@color/line</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
    </style>

    <style name="input_group_block">
        <item name="android:background">@drawable/drawable_input_group_background</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="input_group_image">
        <item name="android:layout_width">@dimen/dp_17</item>
        <item name="android:layout_height">@dimen/dp_17</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:layout_marginStart">@dimen/dp_10</item>
        <item name="android:layout_marginEnd">@dimen/dp_10</item>
    </style>

    <style name="mdtp_ActionButton">
        <item name="android:layout_gravity">clip_horizontal</item>
        <item name="android:focusable">true</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/mdtp_material_button_height</item>
    </style>

    <style name="mdtp_ActionButton.Text">
        <item name="android:textSize">@dimen/mdtp_material_button_textsize</item>
        <item name="android:textColor">@color/mdtp_button_color</item>
        <item name="android:gravity">left|center_horizontal|clip_horizontal</item>
        <item name="android:layout_gravity">clip_horizontal</item>
        <item name="android:background">@drawable/mdtp_material_button_background</item>
        <item name="android:paddingLeft">@dimen/mdtp_material_button_textpadding_horizontal</item>
        <item name="android:paddingRight">@dimen/mdtp_material_button_textpadding_horizontal</item>
        <item name="android:minWidth">@dimen/mdtp_material_button_minwidth</item>
        <item name="android:singleLine">true</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="mdtp_ampm_label">
        <item name="android:textSize">@dimen/mdtp_ampm_label_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mdtp_ampm_text_color</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="mdtp_day_of_week_label_condensed">
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="mdtp_done_button_light">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="mdtp_time_label">
        <item name="android:textSize">@dimen/mdtp_time_label_size</item>
        <item name="android:textColor">@color/mdtp_numbers_text_color</item>
    </style>

    <style name="mdtp_time_label_small">
        <item name="android:textSize">@dimen/mdtp_time_label_subscript_size</item>
        <item name="android:layout_marginBottom">@dimen/mdtp_time_label_shift</item>
    </style>

    <style name="mdtp_time_label_thin">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="my_button">
        <item name="android:textSize">@dimen/dp_17</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">left|center_horizontal|clip_horizontal</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:background">@drawable/drawable_button</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minWidth">150dp</item>
        <item name="android:lines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_centerHorizontal">true</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/calibri_light</item>
    </style>

    <style name="my_button2">
        <item name="android:textSize">@dimen/dp_11</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">left|center_horizontal|clip_horizontal</item>
        <item name="android:layout_gravity">left|center_horizontal|clip_horizontal</item>
        <item name="android:background">@drawable/drawable_button</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:lines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_centerHorizontal">true</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="my_cardview">
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/drawable_cardview</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="my_cardview2">
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/drawable_cardview_2</item>
        <item name="android:padding">@dimen/dp_20</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="my_edittext">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:textColorHint">@color/et_placeholder</item>
        <item name="android:gravity">right|center_horizontal|clip_horizontal</item>
        <item name="android:background">@drawable/drawable_edittext</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="my_edittext_super">
        <item name="android:orientation">@null</item>
        <item name="android:background">@drawable/drawable_edittext_background</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="my_edittext_transparent">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:textColorHint">@color/et_placeholder</item>
        <item name="android:gravity">right|center_horizontal|clip_horizontal</item>
        <item name="android:background">@drawable/drawable_edittext_transparent</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="my_input_group_edittext">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:textColorHint">@color/et_placeholder</item>
        <item name="android:gravity">right|center_horizontal|clip_horizontal</item>
        <item name="android:background">@drawable/drawable_input_group_edittext</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="my_lbl">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/dp_20</item>
        <item name="android:layout_marginBottom">@dimen/dp_5</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_light</item>
    </style>

    <style name="my_lbl_bold">
        <item name="android:textSize">@dimen/dp_14</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_bold</item>
    </style>

    <style name="my_textarea">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:textColorHint">@color/et_placeholder</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:background">@drawable/drawable_edittext</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxLines">5</item>
        <item name="android:minLines">5</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:inputType">
            none|text|textCapCharacters|textCapSentences|textShortMessage|textPassword|textPhonetic
        </item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="my_value">
        <item name="android:textSize">@dimen/dp_18</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:padding">@dimen/dp_10</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="panel">
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/drawable_rounded_white_back</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/dp_20</item>
    </style>

    <style name="panel_body">
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/dp_10</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="panel_header">
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/drawable_panel_header_back</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="panel_title">
        <item name="android:textSize">@dimen/dp_12</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">@dimen/dp_10</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/calibri_bold</item>
    </style>

    <style name="spinner_with_arrow">
        <item name="android:textSize">@dimen/sp_12</item>
        <item name="android:textColor">@color/et_text</item>
        <item name="android:textColorHint">@color/et_placeholder</item>
        <item name="android:gravity">right|center_horizontal|clip_horizontal</item>
        <item name="android:background"> @drawable/drawable_spinner_with_arrow</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:singleLine">true</item>
        <item name="android:fontFamily">@font/calibri_regular</item>
    </style>

    <style name="toolbar">
        <item name="android:background">@color/colorPrimaryDark</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">?attr/actionBarSize</item>
        <item name="android:paddingStart">@dimen/dp_5</item>
        <item name="android:paddingEnd">@dimen/dp_5</item>
    </style>

    <style name="toolbar_main_title">
        <item name="android:textSize">@dimen/dp_14</item>
        <item name="android:textColor">@color/rdo_gender_select</item>
        <item name="android:ellipsize">end</item>
        <item name="android:padding">@dimen/dp_3</item>
        <item name="android:clickable">false</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:singleLine">true</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:fontFamily">@font/calibri_light</item>
    </style>

    <style name="vertical_line">
        <item name="android:background">@color/line</item>
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">match_parent</item>
    </style>
</resources>
