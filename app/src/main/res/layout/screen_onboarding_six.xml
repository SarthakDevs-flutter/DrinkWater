<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_transparant"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_20"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/dp_20"
                android:fontFamily="@font/calibri_bold"
                android:gravity="center"
                android:includeFontPadding="true"
                android:text="@string/str_wakeup_time"
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_20" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txt_wakeup_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:background="@drawable/drawable_edittext_black_overlay"
                android:fontFamily="@font/calibri_light"
                android:includeFontPadding="false"
                android:text="08:00 AM"
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_20" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/dp_20"
                android:fontFamily="@font/calibri_bold"
                android:gravity="center"
                android:includeFontPadding="true"
                android:text="@string/str_bed_time"
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_20" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txt_bed_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:background="@drawable/drawable_edittext_black_overlay"
                android:fontFamily="@font/calibri_light"
                android:includeFontPadding="false"
                android:text="10:00 PM"
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_20" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/dp_20"
                android:fontFamily="@font/calibri_bold"
                android:gravity="center"
                android:includeFontPadding="true"
                android:text="@string/str_interval"
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_20" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <RadioGroup
                    android:id="@+id/radioGroup1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginTop="@dimen/dp_20"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rdo_15"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rdo_back_3"
                        android:button="@null"
                        android:fontFamily="@font/calibri_regular"
                        android:text="15 Mins"
                        android:textColor="@drawable/rdo_back_3" />

                    <RadioButton
                        android:id="@+id/rdo_30"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:background="@drawable/rdo_back_3"
                        android:button="@null"
                        android:checked="true"
                        android:fontFamily="@font/calibri_regular"
                        android:text="30 Mins"
                        android:textColor="@drawable/rdo_back_3" />

                    <RadioButton
                        android:id="@+id/rdo_45"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:background="@drawable/rdo_back_3"
                        android:button="@null"
                        android:fontFamily="@font/calibri_regular"
                        android:text="45 Mins"
                        android:textColor="@drawable/rdo_back_3" />

                    <RadioButton
                        android:id="@+id/rdo_60"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_5"
                        android:background="@drawable/rdo_back_3"
                        android:button="@null"
                        android:fontFamily="@font/calibri_regular"
                        android:text="1 Hour"
                        android:textColor="@drawable/rdo_back_3" />
                </RadioGroup>
            </HorizontalScrollView>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/lbl_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/dp_20"
                android:fontFamily="@font/calibri_light"
                android:includeFontPadding="true"
                android:text=""
                android:textColor="@color/rdo_gender_select"
                android:textSize="@dimen/dp_15" />

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
