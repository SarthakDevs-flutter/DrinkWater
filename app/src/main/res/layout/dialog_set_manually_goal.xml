<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_transparant"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/drawable_rounded_white_back"
            android:orientation="vertical"
            android:paddingStart="@dimen/dp_10"
            android:paddingEnd="@dimen/dp_10">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/dp_20"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:fontFamily="@font/calibri_light"
                android:gravity="center"
                android:includeFontPadding="true"
                android:text="@string/str_set_daily_goal"
                android:textColor="@color/set_daily_goal"
                android:textSize="@dimen/dp_20" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/lbl_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/transparent"
                    android:fontFamily="@font/calibri_bold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="4"
                    android:paddingStart="@dimen/dp_10"
                    android:paddingEnd="@dimen/dp_10"
                    android:text="4500"
                    android:textColor="@color/daily_goal_no"
                    android:textSize="@dimen/dp_30" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/lbl_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:fontFamily="@font/calibri_bold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="ml"
                    android:textColor="@color/daily_goal_no"
                    android:textSize="@dimen/dp_20" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbarGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_25"
                android:backgroundTint="@color/black_20"
                android:max="8000"
                android:progressTint="@color/rdo_gender_select"
                android:thumb="@drawable/custom_thumb2" />

            <RelativeLayout
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dp_20"
                android:background="@drawable/drawable_button"
                android:minWidth="@dimen/dp_120">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/calibri_light"
                    android:includeFontPadding="true"
                    android:text="@string/str_save"
                    android:textColor="@color/white"
                    android:textSize="@dimen/dp_15" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dp_10"
                android:minWidth="@dimen/dp_120">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/calibri_light"
                    android:includeFontPadding="true"
                    android:paddingTop="@dimen/dp_10"
                    android:paddingBottom="@dimen/dp_10"
                    android:text="@string/str_cancel"
                    android:textColor="@color/cancel_color"
                    android:textSize="@dimen/dp_15" />
            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_15"
                android:fontFamily="@font/calibri_regular"
                android:includeFontPadding="true"
                android:text="@string/str_note"
                android:textColor="@color/note_color"
                android:textSize="@dimen/dp_11" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
